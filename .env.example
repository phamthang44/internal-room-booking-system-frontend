# API base (no trailing slash). Paths in code are like `/auth/login` → full `/api/v1/auth/...`.
# Local: point at your backend directly.
VITE_API_URL=http://localhost:3000/api/v1

# Vercel / HTTPS production: the browser cannot call http:// (mixed content). Use a same-origin
# path and proxy the request in vercel.json (see repo root `vercel.json`). Set in Vercel env:
# VITE_API_URL=/api/v1
# Then edit `vercel.json` → `destination` to match your backend base URL (keep `/api/v1/:path*` in sync).

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# Environment
VITE_ENVIRONMENT=development
